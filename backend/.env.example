# Server
# cPanel Node.js automātiski iestata PORT — nelabot manuāli uz servera
PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1

# cPanel: frontend build mape (frontend/dist saturs → public/)
STATIC_DIR=./public

# Database (cPanel: izmantojiet MySQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trio_serv
DB_USER=trio_user
DB_PASSWORD=change_me

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=24h

# AI Services
OPENAI_API_KEY=sk-...
GOOGLE_SPEECH_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# File uploads (cPanel: lokālais storage vai S3)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS (cPanel: jūsu domēns)
CORS_ORIGIN=https://yourdomain.lv
